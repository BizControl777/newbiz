{
  "name": "bizcontroller-360",
  "version": "1.0.0",
  "description": "Sistema de Gestão de Stock & Vendas",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "start": "electron . --no-sandbox --disable-setuid-sandbox",
    "dev": "node electron/server.js",
    "server": "node --watch electron/server.js",
    "build": "electron-builder",
    "electron": "electron . --no-sandbox --disable-setuid-sandbox",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "BizControl",
  "license": "MIT",
  "build": {
    "appId": "com.bizcontrol.360",
    "productName": "BizController 360",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icon/iconiconbiz.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon/iconiconbiz.ico",
      "uninstallerIcon": "icon/iconiconbiz.ico",
      "shortcutName": "BizController 360"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "node-machine-id": "^1.1.12",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^26.0.0",
    "electron-builder": "^24.1.1"
  }
}
